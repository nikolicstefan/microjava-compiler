program codeGeneratorTestB
	int x, y, z;
	char c1, c2;
	bool flag;
	char charArray[];
	int charArrayLength;
	int array[], arrayLength;
	int result;
	int arrayO[], arrayE[];
	set setO, setE, setU;
	int fact1, fact2;
	const int min = 50;
	const int max = 100;
	const int cap = 10;
	const char c = 'a';
	const bool forever = true;
	const bool never = false;
{
	int echo(int x)
	{
		return x;
	}
	
	int sum(int a, int b)
	{
		return a + b;
	}
	
	int mul(int a, int b)
	{
		return a * b;
	}
	
	int square(int a)
	{
		return a * a;
	}
	
	int sumOfSquares(int array[])
		int sum, i;
	{
		sum = 0;
		if (array != null) {
			i = 0;
			do {
				sum = sum + square(array[i]);
				i++;
			} while (i < arrayLength);
		}
		return sum;
	}
	
	int dec(int a)
	{
		a--;
		return a;
	}
	
	bool isOutOfRange(int a) {
		// if (a < min || a > max) return true;
		// else return false;
		if (a >= min && a <= max) return false;
		else return true;
	}
	
	int generateElement(int i, bool odd)
		int adjust;
	{
		if (odd == true) adjust = 1;
		else adjust = 0;
		i++;
		return i * 2 - adjust;
	}
	
	void printOutOfRange(int i)
	{
		print('i'); print(' '); print('='); print(' '); print(i); print(':'); print(' ');
		print('o'); print('u'); print('t'); print(' ');
		print('o'); print('f'); print(' ');
		print('r'); print('a'); print('n'); print('g'); print('e');
		print(eol);
		return;
	}

	void main()
		int i, j;
		int swap;
	{
		x = 5;
		y = 10;
		z = x + y * 2;
		print(z); // 25
		print(eol);
		z = (x + y) * 2;
		print(z); // 30
		print(eol);
		
		c1 = 'A';
		c2 = 'B';
		flag = true;
		if (flag == false || true) print(c1); // A
		else print(c2);
		print(eol);
		print(flag); // true
		print(eol);

		charArrayLength = 5;
		charArray = new char[charArrayLength];
		x = ord('a');
		i = 0;
		do {
			charArray[i] = chr(x);
			x++;
			i++;
		} while (i < charArrayLength);
		i = 0;
		do {
			print(charArray[i]);
			i++;
		} while (i < charArrayLength);
		print(eol);
		// abcde
		
		arrayLength = 5;
		array = new int[arrayLength];	
		i = 0;	
		do {
			array[i] = i + 1;
			i++;
		} while (i < arrayLength);
		result = square map array;
		print(result); // 55
		print(eol);
				
		print(sumOfSquares(array)); // 55
		print(eol);
		
		array = null;
		print(sumOfSquares(array)); // 0
		print(eol);
		
		arrayLength = 10;
		array = new int[arrayLength];
		i = 0;
		do {
			read(array[i]);
			if (array[i] == 0) continue;
			array[i] = 100 / array[i];
		} while (i < arrayLength - 1, i++);
		result = echo map array;
		print(result);
		print(eol);
		
		arrayO = new int[5];
		arrayE = new int[5];
		setO = new set[5];
		setE = new set[5];
		setU = new set[10];
		i = 0;
		do {
			arrayO[i] = generateElement(i, true);
			arrayE[i] = generateElement(i, false);
		} while (i < 4, i++);
		addAll(setO, arrayO);
		addAll(setE, arrayE);
		setU = setO union setE;
		print(setU); // 1 3 5 7 9 2 4 6 8 10
		print(eol);
		
		arrayO = new int[cap];
		arrayE = new int[cap];
		setO = new set[cap];
		setE = new set[cap];
		setU = new set[2 * cap];
		read(fact1);
		read(fact2);
		i = 0;
		do {
			arrayO[i] = mul(i, fact1);
			arrayE[i] = mul(i, fact2);
		} while (i < cap - 1, i++);
		addAll(setO, arrayO);
		print(setO);
		print(eol);
		addAll(setE, arrayE);
		print(setE);
		print(eol);
		setU = setO union setE;
		print(setU);
		print(eol);
		setO = null;
		setE = null;
		setU = null;
		
		i = 0;
		do {
			read(x);
			read(y);
			if (isOutOfRange(x)) {
				printOutOfRange(i);
				array[i] = 0;
				i++;
				continue;
			}
			if (isOutOfRange(y)) {
				printOutOfRange(i);
				array[i] = 0;
				i++;
				continue;
			}
			if (x < y) {
				swap = x;
				x = y;
				y = swap;
			}
			array[i] = sum(x, -y);
			i++;
		} while (i < arrayLength);
		result = dec map array;
		print(result);
		print(eol);
		
		{
			i = 0;
			result = 0;
			do {
				if (i == 5) break;
				result = result + i;
				i++;
			} while ();
			print(result, 5); // 10
			print(eol);
		}
				
		i = 1;
		x = 0;
		do {
			if (i == 4) {
				i++;
				continue;
			}
			j = 0;
			do {
				if (j == 0) continue;
				if (i > 4 && j > i - 1) break;
				print(j);
				x++;
			} while (j < i, j++);
			print('#');
			print(x);
			print(eol);
			if (x > 30) break;
			i++;
		} while (i < 10);
		// 1#1
        // 12#3
        // 123#6
        // 1234#10
        // 12345#15
        // 123456#21
        // 1234567#28
        // 12345678#36
	}
}

